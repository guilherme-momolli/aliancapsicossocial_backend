# =========================================================================
# CONFIGURAÇÕES DE HOMOLOGAÇÃO (EXEMPLO)
# copie este arquivo para .env.homolog e preencha as variáveis de ambiente
# =========================================================================

# Porta da API
PORT=8080

# Perfil Ativo do Spring
SPRING_PROFILES_ACTIVE=homolog

# Conexão com o Banco de Dados PostgreSQL
DB_HOST=postgres-homolog
DB_PORT=5432
DB_NAME=aliancapsicossocial_homolog
DB_USERNAME=postgres
DB_PASSWORD=insira_senha_homolog_segura

# Configurações do Hibernate/JPA
DB_DDL_AUTO=update
DB_SHOW_SQL=true
DB_FORMAT_SQL=true

# Credenciais do Swagger / Spring Security
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=admin

# ==========================================
# CONFIGURAÇÕES AWS (HOMOLOGAÇÃO)
# ==========================================
AWS_REGION=sa-east-1
# Credenciais AWS (Para rodar localmente com credenciais reais de homolog. Se rodar no ECS Fargate com Task Role, deixe vazio)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Nome do bucket S3 de homologação
AWS_S3_BUCKET_NAME=aliancap-uploads-homolog-bucket
# E-mail remetente do SES homologado
AWS_SES_FROM_EMAIL=contato-homolog@aliancapsicossocial.com.br
# Endpoints customizados (deixe vazio para usar a nuvem real da AWS)
AWS_S3_ENDPOINT=
AWS_SES_ENDPOINT=

