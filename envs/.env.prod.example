# =========================================================================
# CONFIGURAÇÕES DE PRODUÇÃO (EXEMPLO)
# copie este arquivo para .env.prod e preencha as variáveis de ambiente
# =========================================================================

# Porta da API
PORT=8080

# Perfil Ativo do Spring
SPRING_PROFILES_ACTIVE=prod

# Conexão com o Banco de Dados PostgreSQL
DB_HOST=postgres-prod
DB_PORT=5432
DB_NAME=aliancapsicossocial_prod
DB_USERNAME=postgres
DB_PASSWORD=insira_senha_producao_altamente_segura

# Configurações do Hibernate/JPA
# Em produção, nunca utilize 'update' ou 'create-drop'. Utilize 'validate' ou 'none'.
DB_DDL_AUTO=validate
DB_SHOW_SQL=false
DB_FORMAT_SQL=false

# Credenciais do Swagger / Spring Security
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=insira_senha_producao_altamente_segura

# ==========================================
# CONFIGURAÇÕES AWS (PRODUÇÃO)
# ==========================================
AWS_REGION=sa-east-1
# Credenciais AWS (Mantenha vazias em produção! ECS Task Role obterá permissões seguras do IAM automaticamente)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Nome do bucket S3 oficial de produção
AWS_S3_BUCKET_NAME=aliancap-uploads-prod-bucket
# E-mail remetente oficial de produção verificado no SES
AWS_SES_FROM_EMAIL=contato@aliancapsicossocial.com.br
# Endpoints customizados (deixe sempre vazio em produção)
AWS_S3_ENDPOINT=
AWS_SES_ENDPOINT=

# ==========================================
# SEGURANÇA E CORS (PRODUÇÃO)
# ==========================================
# Gerar chave aleatória forte de 256 bits (ex: openssl rand -hex 32)
JWT_SECRET=insira_uma_chave_secreta_longa_e_altamente_segura_de_producao
# Domínios front-end autorizados separados por vírgula (ex: https://aliancapsicossocial.com.br)
CORS_ALLOWED_ORIGINS=https://aliancapsicossocial.com.br
