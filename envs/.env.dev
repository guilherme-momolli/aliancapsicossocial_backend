# =========================================================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO (EXEMPLO)
# copie este arquivo para .env.dev e preencha as variáveis de ambiente
# =========================================================================

# Porta da API
PORT=8080

# Perfil Ativo do Spring
SPRING_PROFILES_ACTIVE=dev

# Conexão com o Banco de Dados PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aliancapsicossocial
DB_USERNAME=postgres
DB_PASSWORD=0000

# Configurações do Hibernate/JPA
DB_DDL_AUTO=update
DB_SHOW_SQL=true
DB_FORMAT_SQL=true

# Credenciais do Swagger / Spring Security
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=admin

# ==========================================
# CONFIGURAÇÕES AWS (DESENVOLVIMENTO)
# ==========================================
AWS_REGION=us-east-1
# Credenciais fictícias de desenvolvimento (podem ser substituídas por chaves reais ou LocalStack)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Nome do bucket S3 local/desenvolvimento
AWS_S3_BUCKET_NAME=aliancap-uploads-dev-bucket
# E-mail remetente do SES local/desenvolvimento
AWS_SES_FROM_EMAIL=guilherme.momolli@gmail.com
# Endpoint customizado para o LocalStack (opcional, ex: http://localhost:4566)
AWS_S3_ENDPOINT=
AWS_SES_ENDPOINT=

# ==========================================
# SEGURANÇA E CORS (DESENVOLVIMENTO)
# ==========================================
JWT_SECRET=segredo-super-secreto-e-longo-para-desenvolvimento-123456
CORS_ALLOWED_ORIGINS=*
